{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "vite",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/favicon.svg",
      "destination": "/favicon.svg"
    },
    {
      "source": "/icons.svg",
      "destination": "/icons.svg"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
